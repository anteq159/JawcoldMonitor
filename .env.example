DB_PASSWORD=change_me_strong_password
SECRET_KEY=change_me_at_least_32_chars_random_string
PREVIEW_MODE=false
RS485_PORTS=/dev/ttyUSB0
RS485_BAUDRATE=9600
ALLOWED_ORIGINS=http://localhost

# --- Alarmy systemowe ---
# Urzadzenie offline dluzej niz N minut (0 wylacza)
OFFLINE_ALARM_MINUTES=5
# Alarm zapelnienia dysku powyzej N procent (0 wylacza)
DISK_ALARM_PERCENT=90

# --- Powiadomienia e-mail (puste SMTP_HOST wylacza kanal) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
ALERT_EMAIL_TO=

# --- Powiadomienia Telegram (puste pola wylaczaja kanal) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Ktore kanaly dostaja alarmy systemowe/sprzetowe: email,telegram
NOTIFY_SYSTEM_CHANNELS=

# --- Automatyczne kopie zapasowe ---
BACKUP_AUTO_ENABLED=false
BACKUP_INTERVAL_HOURS=24
BACKUP_DIR=backups
BACKUP_RETENTION_COUNT=14
